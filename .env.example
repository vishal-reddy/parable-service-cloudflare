# Cloudflare Workers Secrets (set via `wrangler secret put`)
# KINDE_DOMAIN=https://your-domain.kinde.com
# KINDE_CLIENT_ID=your_client_id
# KINDE_CLIENT_SECRET=your_client_secret
# KINDE_REDIRECT_URI=https://your-worker.workers.dev/kinde/callback
# KINDE_LOGOUT_REDIRECT_URI=https://your-worker.workers.dev
# KINDE_AUDIENCE=https://parable.kecker.co

# Local development overrides (copy to .dev.vars)
KINDE_DOMAIN=https://kecker.kinde.com
KINDE_CLIENT_ID=
KINDE_CLIENT_SECRET=
KINDE_REDIRECT_URI=http://localhost:8787/kinde/callback
KINDE_LOGOUT_REDIRECT_URI=http://localhost:8787
KINDE_AUDIENCE=https://parable.kecker.co
WEATHER_API_BASE_URL=https://api.weather.gov
SESSION_SECRET=change-me-to-a-random-32-char-string
